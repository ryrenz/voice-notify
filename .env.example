# voice-notify optional configuration
# All keys below are OPTIONAL. Default mode uses local TTS, no keys needed.

# --- Fish Audio (character voices) ---
# Register at https://fish.audio -> Account -> API Keys
# FISH_API_KEY=

# --- LLM summarization (for "api" mode under Fish Audio) ---
# Without this, Fish "api" mode cannot summarize what Claude did.
# Get DeepSeek key at https://platform.deepseek.com
# DEEPSEEK_API_KEY=

# --- Alternative: OpenAI-compatible LLM ---
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
